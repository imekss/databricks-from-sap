{
  "datasets": [
    {
      "name": "pnl_data",
      "displayName": "P&L Data",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  n3n3.gold.profit_and_loss\n",
        "ORDER BY\n",
        "  sort_order"
      ],
      "columns": [
        {
          "displayName": "Amount EUR Millions",
          "description": "",
          "expression": "`amount_eur` / 1000000"
        },
        {
          "displayName": "Gross Sales Amount",
          "description": "",
          "expression": "CASE WHEN `pnl_line_name` = 'Gross Sales' THEN `amount_eur` / 1000000 ELSE 0 END"
        },
        {
          "displayName": "Net Sales Amount",
          "description": "",
          "expression": "CASE WHEN `pnl_line_name` = 'Net Sales' THEN `amount_eur` / 1000000 ELSE 0 END"
        },
        {
          "displayName": "Gross Profit Amount",
          "description": "",
          "expression": "CASE WHEN `pnl_line_name` = 'Gross Profit' THEN `amount_eur` / 1000000 ELSE 0 END"
        },
        {
          "displayName": "EBITDA Amount",
          "description": "",
          "expression": "CASE WHEN `pnl_line_name` = 'EBITDA' THEN `amount_eur` / 1000000 ELSE 0 END"
        },
        {
          "displayName": "Version Description",
          "description": "",
          "expression": "CASE WHEN `version` = 'ACT' THEN 'Actual' WHEN `version` = 'BUD' THEN 'Budget' WHEN `version` = 'FC1' THEN 'Forecast 1' ELSE `version` END"
        },
        {
          "displayName": "Waterfall Category",
          "description": "",
          "expression": "CASE WHEN `pnl_line_name` IN ('Gross Sales') THEN 'Revenue' WHEN `pnl_line_name` IN ('Net Sales', 'Gross Profit', 'EBITDA') THEN 'Total' ELSE 'Expense' END"
        },
        {
          "displayName": "Country Name",
          "description": "",
          "expression": "CASE WHEN `company_country` = 'US' THEN 'United States of America' WHEN `company_country` = 'DE' THEN 'Germany' WHEN `company_country` = 'FR' THEN 'France' WHEN `company_country` = 'IT' THEN 'Italy' WHEN `company_country` = 'ES' THEN 'Spain' WHEN `company_country` = 'NL' THEN 'Netherlands' WHEN `company_country` = 'JP' THEN 'Japan' WHEN `company_country` = 'SN' THEN 'Senegal' ELSE `company_country` END"
        }
      ],
      "catalog": "n3n3",
      "schema": "default"
    },
    {
      "name": "pnl_margins",
      "displayName": "P&L Margins",
      "queryLines": [
        "WITH totals AS (\n",
        "  SELECT\n",
        "    company_code,\n",
        "    company_name,\n",
        "    fiscal_year,\n",
        "    fiscal_period,\n",
        "    version,\n",
        "    pnl_line_name,\n",
        "    SUM(amount_eur) AS total_amount\n",
        "  FROM\n",
        "    n3n3.gold.profit_and_loss\n",
        "  WHERE\n",
        "    pnl_line_name IN ('Net Sales', 'Gross Profit', 'EBITDA')\n",
        "  GROUP BY\n",
        "    company_code,\n",
        "    company_name,\n",
        "    fiscal_year,\n",
        "    fiscal_period,\n",
        "    version,\n",
        "    pnl_line_name\n",
        ")\n",
        "SELECT\n",
        "  company_code,\n",
        "  company_name,\n",
        "  fiscal_year,\n",
        "  fiscal_period,\n",
        "  version,\n",
        "  SUM(\n",
        "    CASE\n",
        "      WHEN pnl_line_name = 'Gross Profit' THEN total_amount\n",
        "      ELSE 0\n",
        "    END\n",
        "  ) AS gross_profit_eur,\n",
        "  SUM(\n",
        "    CASE\n",
        "      WHEN pnl_line_name = 'Net Sales' THEN total_amount\n",
        "      ELSE 0\n",
        "    END\n",
        "  ) AS net_sales_eur,\n",
        "  SUM(\n",
        "    CASE\n",
        "      WHEN pnl_line_name = 'EBITDA' THEN total_amount\n",
        "      ELSE 0\n",
        "    END\n",
        "  ) AS ebitda_eur\n",
        "FROM\n",
        "  totals\n",
        "GROUP BY\n",
        "  company_code,\n",
        "  company_name,\n",
        "  fiscal_year,\n",
        "  fiscal_period,\n",
        "  version"
      ],
      "columns": [
        {
          "displayName": "Gross Margin Pct",
          "description": "Weighted gross margin percentage",
          "expression": "SUM(`gross_profit_eur`) / NULLIF(SUM(`net_sales_eur`), 0)"
        },
        {
          "displayName": "EBITDA Margin Pct",
          "description": "Weighted EBITDA margin percentage",
          "expression": "SUM(`ebitda_eur`) / NULLIF(SUM(`net_sales_eur`), 0)"
        }
      ]
    },
    {
      "name": "geo_sales",
      "displayName": "Net Sales by Country",
      "queryLines": [
        "SELECT\n",
        "  company_country,\n",
        "  CASE\n",
        "    WHEN company_country = 'US' THEN 'United States of America'\n",
        "    WHEN company_country = 'DE' THEN 'Germany'\n",
        "    WHEN company_country = 'FR' THEN 'France'\n",
        "    WHEN company_country = 'IT' THEN 'Italy'\n",
        "    WHEN company_country = 'ES' THEN 'Spain'\n",
        "    WHEN company_country = 'NL' THEN 'Netherlands'\n",
        "    WHEN company_country = 'JP' THEN 'Japan'\n",
        "    WHEN company_country = 'SN' THEN 'Senegal'\n",
        "    ELSE company_country\n",
        "  END AS country_name,\n",
        "  fiscal_year,\n",
        "  fiscal_period,\n",
        "  version,\n",
        "  pnl_line_name,\n",
        "  SUM(amount_eur) / 1000000 AS amount_millions\n",
        "FROM\n",
        "  n3n3.gold.profit_and_loss\n",
        "WHERE\n",
        "  pnl_line_name = 'Net Sales'\n",
        "GROUP BY\n",
        "  ALL"
      ],
      "columns": [
        {
          "displayName": "Country ISO3",
          "description": "",
          "expression": "CASE WHEN `company_country` = 'US' THEN 'USA' WHEN `company_country` = 'DE' THEN 'DEU' WHEN `company_country` = 'FR' THEN 'FRA' WHEN `company_country` = 'IT' THEN 'ITA' WHEN `company_country` = 'ES' THEN 'ESP' WHEN `company_country` = 'NL' THEN 'NLD' WHEN `company_country` = 'JP' THEN 'JPN' WHEN `company_country` = 'SN' THEN 'SEN' ELSE `company_country` END"
        }
      ],
      "catalog": "n3n3",
      "schema": "default"
    }
  ],
